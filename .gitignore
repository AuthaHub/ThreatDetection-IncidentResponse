# Local .terraform directories
.terraform/
.terraform.lock.hcl

# Terraform state files (NEVER commit these)
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Terraform plan files (can contain sensitive data)
tfplan
*.tfplan

# Terraform variable files with sensitive data
terraform.tfvars
*.auto.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive documentation (keep locally, not in public repo)
docs/resume-bullets.md

# Crash log files
crash.log
crash.*.log

# SSH keys and certificates
*.pem
*.key
*.crt

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db